# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
venv311/
.venv/
env/

# ── Development / test artifacts ─────────────────────────────────────────────
*.db
*.sqlite3
*.m4a
*.mp3
*.webm
*.wav

# ── macOS metadata files (IMPORTANT: these confuse Cloud Build) ───────────────
._*
.DS_Store

# ── Secrets — never bake into image ───────────────────────────────────────────
.env
.env.*

# ── VCS ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Docker files (not needed inside image) ────────────────────────────────────
docker-compose.yml
.dockerignore

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Python packaging artifacts ────────────────────────────────────────────────
*.egg-info/
dist/
build/

# ── Test files ────────────────────────────────────────────────────────────────
test_*.py
*_test.py